# -------------------------
# Node / React monorepo
# -------------------------

# Node modules
node_modules/

# Build output (React + TS)
dist/
build/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Runtime data
*.pid
*.seeded.json

# Coverage (caso use Jest)
coverage/

# IDE / Sistema
.vscode/
.DS_Store
Thumbs.db

# React specific
# (arquivos de cache criados ao buildar)
frontend/.eslintcache
frontend/node_modules/
frontend/build/

# Backend specific
backend/node_modules/
backend/dist/

# Optional: lock files de outro gerenciador
package-lock.json
yarn.lock
pnpm-lock.yaml